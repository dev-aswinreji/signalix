<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create account"
        android:textSize="22sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/username"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Username (3–20 letters/numbers/_ )"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/generate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Generate UUID token"
        android:layout_marginTop="12dp"
        android:backgroundTint="#6B7280" />

    <TextView
        android:id="@+id/token"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Token will appear here"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/copy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Copy token"
        android:layout_marginTop="8dp"
        android:backgroundTint="#4B5563" />

    <TextView
        android:id="@+id/warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Important: Store this token safely. If you lose it, recovery is not possible."
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/continue_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Continue to login"
        android:layout_marginTop="16dp" />
</LinearLayout>
